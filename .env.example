# API Keys for Breaking-Point Mod Tools
# Copy this file to .env and fill in your actual API keys

# Anthropic Claude API (Required for modding agent)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Google Gemini API (Required for portrait generation)
GEMINI_API_KEY=xxxxx

# Tavily Search API (Optional - falls back to DuckDuckGo if not set)
TAVILY_API_KEY=tvly-xxxxx

# Google Custom Search (Optional)
GOOGLE_API_KEY=xxxxx
GOOGLE_CX=xxxxx

# Mod Root Path (Optional - auto-detected from descriptor.mod)
# MOD_ROOT=/path/to/your/mod
