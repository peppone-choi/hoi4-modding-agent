# ============================================================
# HOI4 Modding Agent - Configuration
# Copy this file to .env and fill in your API keys
# ============================================================

# AI Provider: anthropic, gemini, openai, ollama
AI_PROVIDER=gemini

# --- Anthropic Claude (if AI_PROVIDER=anthropic) ---
# ANTHROPIC_API_KEY=sk-ant-xxxxx
# CLAUDE_MODEL=claude-sonnet-4-6

# --- Google Gemini (if AI_PROVIDER=gemini) ---
GEMINI_API_KEY=your-gemini-api-key-here
# GEMINI_MODEL=gemini-3-flash-preview

# --- OpenAI GPT (if AI_PROVIDER=openai) ---
# OPENAI_API_KEY=sk-xxxxx
# OPENAI_MODEL=gpt-4o-mini

# --- Ollama Local (if AI_PROVIDER=ollama) ---
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen3.5:4b

# --- Search (Optional - falls back to DuckDuckGo) ---
# TAVILY_API_KEY=tvly-xxxxx
# GOOGLE_API_KEY=xxxxx
# GOOGLE_CX=xxxxx

# --- Portrait Style ---
PORTRAIT_BG_TOP=#bfdc7f
PORTRAIT_BG_BOTTOM=#0a0f0a
PORTRAIT_BG_GRADIENT=true
PORTRAIT_SCANLINES_ENABLED=true
