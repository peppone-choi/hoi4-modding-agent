# API Keys for Breaking-Point Mod Tools
# Copy this file to .env and fill in your actual API keys

# AI Provider Selection (anthropic or ollama)
AI_PROVIDER=anthropic

# Anthropic Claude API (Required if AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Ollama Configuration (Required if AI_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:70b

# Google Gemini API (Required for portrait generation)
GEMINI_API_KEY=xxxxx

# Tavily Search API (Optional - falls back to DuckDuckGo if not set)
TAVILY_API_KEY=tvly-xxxxx

# Google Custom Search (Optional)
GOOGLE_API_KEY=xxxxx
GOOGLE_CX=xxxxx

# Mod Root Path (Optional - auto-detected from descriptor.mod)
# MOD_ROOT=/path/to/your/mod
